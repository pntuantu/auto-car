{
    "configurations": [
        {
            "name": "ESP32",
            "includePath": [
                "${workspaceFolder}/**",
                "${IDF_PATH}/components/**",
                "${IDF_TOOLS_PATH}/tools/xtensa-esp32-elf/esp-2021r2-patch3-xtensa-esp32-elf/lib/gcc/xtensa-esp32-elf/8.4.0/include",
                "${IDF_PATH}/components/esp_rom/include"
