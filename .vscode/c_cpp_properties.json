            "compilerPath": "${IDF_TOOLS_PATH}/tools/xtensa-esp32-elf/esp-2021r2-patch3-xtensa-esp32-elf/bin/xtensa-esp32-elf-gcc",
            "cStandard": "c99",
            "cppStandard": "c++17",
            "intelliSenseMode": "gcc-x64"
        }
    ],
    "version": 4
}
